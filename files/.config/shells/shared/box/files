# Syntax highlighting
# vim: filetype=sh

# Shortcuts to files I edit regularly
alias zsrc="$EDITOR $HOME/documents/dot/files/.config/shells/zsh/.zshrc"
alias zdir="$EDITOR $HOME/documents/dot/files/.config/shells/zsh/nameddir"
alias bsrc="$EDITOR $HOME/documents/dot/files/.config/shells/bash/.bashrc"
alias bdir="$EDITOR $HOME/documents/dot/files/.config/shells/bash/nameddir"
alias alrc="$EDITOR $HOME/documents/dot/files/.config/shells/shared/aliases"
alias firc="$EDITOR $HOME/documents/dot/files/.config/shells/shared/files"
alias hkrc="$EDITOR $HOME/documents/dot/files/.config/sxhkd/sxhkdrc"
alias bwrc="$EDITOR $HOME/documents/dot/files/.config/bspwm/bspwmrc"
alias virc="$EDITOR $HOME/documents/dot/files/.config/nvim/init.vim"
