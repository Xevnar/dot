# Syntax highlighting
# vim: filetype=sh

# Shortcuts to files I edit regularly
alias zsrc="$EDITOR $DOTDIR/.config/shells/zsh/.zshrc"
alias zdir="$EDITOR $DOTDIR/.config/shells/zsh/nameddir"
alias bsrc="$EDITOR $DOTDIR/.config/shells/bash/.bashrc"
alias alrc="$EDITOR $DOTDIR/.config/shells/shared/aliases"
alias firc="$EDITOR $DOTDIR/.config/shells/shared/files"
alias dirc="$EDITOR $DOTDIR/.config/shells/shared/nameddir"
alias hkrc="$EDITOR $DOTDIR/.config/sxhkd/sxhkdrc"
alias bwrc="$EDITOR $DOTDIR/.config/bspwm/box/bspwmrc"
alias virc="$EDITOR $DOTDIR/.config/nvim/box/init.vim"
