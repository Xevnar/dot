# Syntax highlighting
# vim: filetype=sh

# Shortcuts to files I edit regularly
alias zsrc="$EDITOR $ZDOTDIR/.zshrc"
alias zdir="$EDITOR $ZDOTDIR/nameddir"
alias bsrc="$EDITOR $BDOTDIR/.bashrc"
alias bdir="$EDITOR $BDOTDIR/nameddir"
alias alrc="$EDITOR $HOME/documents/dot/.config/shells/shared/aliases"
alias firc="$EDITOR $HOME/documents/dot/.config/shells/shared/files"
alias hkrc="$EDITOR $HOME/documents/dot/.config/sxhkd/sxhkdrc"
alias bwrc="$EDITOR $HOME/documents/dot/.config/bspwm/bspwmrc"
alias virc="$EDITOR $HOME/documents/dot/.config/nvim/init.vim"
