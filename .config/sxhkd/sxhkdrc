# Toggle the focused node between fullscreen mode and the previous state
super + f
  bspc node -t ~fullscreen

# Toggle the focused node between floating mode and the previous state
super + shift + f
  bspc node -t ~floating

# Toggle the focused node between tiled mode and the previous state
super + t
  bspc node -t ~tiled

# Toggle the focused node between pseudo_tiled mode and the previous state
super + shift + t
  bspc node -t ~pseudo_tiled

control + z
 echo "disabled job control" 2>/dev/null 
